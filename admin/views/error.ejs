<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Erreur · OBM Admin</title>
  <link rel="stylesheet" href="/admin/_static/admin.css">
</head>
<body>
  <% if (user) { %><%- include('partials/topbar', { user, active: null }) %><% } %>
  <main class="admin-main" style="text-align:center; padding-top:80px;">

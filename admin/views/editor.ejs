<%
  const isCase = type === 'cases';
  const title = (isNew ? 'Nouveau ' : 'Éditer ') + (isCase ? 'cas client' : 'article');
  const formAction = isNew
    ? (isCase ? '/admin/cases' : '/admin/blog')
    : (isCase ? '/admin/cases/' + item.slug : '/admin/blog/' + item.slug);
  const d = item && item.data ? item.data : {};
  const content = item && item.content ? item.content : '';
  const subMetrics = (d.subMetrics && Array.isArray(d.subMetrics) && d.subMetrics.length > 0) ? d.subMetrics : [{label:'',value:'',unit:''},{label:'',value:'',unit:''},{label:'',value:'',unit:''}];
  const SITE = 'https://obm-system.com';
  const previewUrl = (isCase ? '/cas-clients/' : '/blog/') + (item ? item.slug : 'mon-article') + '/';
%>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> · OBM Admin</title>
  <link rel="stylesheet" href="/admin/_static/admin.css">
  <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
  <script src="https://cdn.jsdelivr.net/npm/marked@14.1.0/marked.min.js" defer></script>
</head>
<body>
  <%- include('partials/topbar', { user, active: isCase ? 'cases' : 'blog' }) %>

  <main class="admin-main">
    <% if (typeof flash !== 'undefined' && flash) { %><div class="flash flash--success"><%= flash %></div><% } %>

    <header class="page-head">
      <a href="/admin/dashboard" class="back-link">← Retour au dashboard</a>
      <h1><%= title %></h1>
    </header>

    <% if (error) { %><div class="flash flash--error"><%= error %></div><% } %>

    <form method="post" action="<%= formAction %>" class="editor-form">

      <!-- Tabs -->
      <div class="editor-tabs" role="tablist">
        <button type="button" class="editor-tab is-active" data-tab="content">📝 Contenu</button>
        <button type="button" class="editor-tab" data-tab="seo">🔍 SEO &amp; Partage</button>
        <% if (isCase) { %><button type="button" class="editor-tab" data-tab="metrics">📊 Métriques</button><% } %>
      </div>

      <div class="editor-grid">
        <div class="editor-main">

          <!-- ===== Content tab ===== -->
          <section class="editor-tab-pane is-active" data-pane="content">
            <label class="field">
              <span>Titre <em>requis</em></span>
              <input type="text" name="title" required value="<%= d.title || '' %>" placeholder="Titre de l'article" id="f-title">
            </label>

            <label class="field">
              <span>Slug <em>URL : <code><%= isCase ? '/cas-clients/' : '/blog/' %><span data-preview-slug><%= item ? item.slug : 'auto-genere' %></span>/</code></em></span>
              <input type="text" name="slug" value="<%= item ? item.slug : '' %>" placeholder="laisser vide pour génération auto" pattern="[a-z0-9-]*" id="f-slug">
            </label>

            <label class="field">
              <span>Résumé / Lead <em>affiché en preview + utilisé par défaut comme description SEO</em></span>
              <textarea name="excerpt" rows="3" placeholder="1-2 phrases qui résument l'article." id="f-excerpt"><%= d.excerpt || '' %></textarea>
            </label>

            <label class="field">
              <span>Contenu (Markdown)</span>
              <div class="editor-pane">
                <textarea name="content" id="editor-content" rows="22" spellcheck="false" placeholder="# Titre H1&#10;&#10;Paragraphe d'introduction…"><%= content %></textarea>
                <div class="editor-preview" id="editor-preview" aria-hidden="true"></div>
              </div>
              <div class="editor-help">
                <strong>Markdown :</strong>
                <code># H1</code>
                <code>## H2</code>
                <code>**gras**</code>
                <code>*italique*</code>
                <code>[texte](url)</code>
                <code>![alt](image.jpg)</code>
                <code>- liste</code>
                <code>&gt; citation</code>
                <a href="/admin/media" target="_blank" rel="noopener" class="btn btn--ghost btn--xs">📁 Médias ↗</a>
              </div>
            </label>
          </section>

          <!-- ===== SEO tab ===== -->
          <section class="editor-tab-pane" data-pane="seo">

            <!-- SERP preview -->
            <div class="seo-preview">
              <h4 class="seo-preview__head">📍 Aperçu Google</h4>
              <div class="serp">
                <div class="serp__url"><span class="serp__domain"><%= SITE.replace('https://','') %></span><span>›</span><span id="serp-path"><%= previewUrl %></span></div>
                <a class="serp__title" id="serp-title" href="#">—</a>
                <div class="serp__desc" id="serp-desc">—</div>
              </div>
              <h4 class="seo-preview__head" style="margin-top:14px;">📘 Aperçu Facebook / LinkedIn</h4>
              <div class="og-card">
                <div class="og-card__img" id="og-img-prev"></div>
                <div class="og-card__body">
                  <div class="og-card__domain"><%= SITE.replace('https://','').toUpperCase() %></div>
                  <div class="og-card__title" id="og-title-prev">—</div>
                  <div class="og-card__desc" id="og-desc-prev">—</div>
                </div>
              </div>
            </div>

            <fieldset class="field fieldset">
              <legend>Référencement Google</legend>

              <label class="field">
                <span>Titre SEO <em>défaut : titre · OBM SYSTEM · 60 char max</em></span>
                <input type="text" name="metaTitle" value="<%= d.metaTitle || '' %>" placeholder="Optionnel — surcharge le <title>" maxlength="80" id="f-metaTitle">
                <small class="counter" data-counter-for="f-metaTitle">0 / 60 (~optimal)</small>
              </label>

              <label class="field">
                <span>Description SEO <em>défaut : résumé · 155-160 char optimal</em></span>
                <textarea name="seoDescription" rows="3" placeholder="Optionnel — surcharge la meta description" maxlength="220" id="f-seoDescription"><%= d.seoDescription || '' %></textarea>
                <small class="counter" data-counter-for="f-seoDescription">0 / 160 (~optimal)</small>
              </label>

              <label class="field">
                <span>Mots-clés <em>optionnel · séparés par virgule · n'a quasi plus d'impact SEO mais utile pour ton suivi</em></span>
                <input type="text" name="keywords" value="<%= d.keywords || '' %>" placeholder="implants dentaires, marketing dentaire, casablanca">
              </label>

              <label class="field">
                <span>URL canonique <em>défaut : URL de la page · ne modifier que si contenu dupliqué d'ailleurs</em></span>
                <input type="text" name="canonical" value="<%= d.canonical || '' %>" placeholder="<%= SITE %><%= previewUrl %>">
              </label>

              <div class="row-2">
                <label class="checkbox">
                  <input type="checkbox" name="noindex" <%= d.noindex ? 'checked' : '' %>>
                  <span>Noindex <small>(bloquer l'indexation Google)</small></span>
                </label>
                <label class="checkbox">
                  <input type="checkbox" name="nofollow" <%= d.nofollow ? 'checked' : '' %>>
                  <span>Nofollow <small>(ne pas suivre les liens)</small></span>
                </label>
              </div>
            </fieldset>

            <fieldset class="field fieldset">
              <legend>Open Graph (Facebook, WhatsApp, LinkedIn)</legend>

              <label class="field">
                <span>OG Title <em>défaut : titre SEO</em></span>
                <input type="text" name="ogTitle" value="<%= d.ogTitle || '' %>" placeholder="Optionnel — affiché dans les partages" id="f-ogTitle">
              </label>

              <label class="field">
                <span>OG Description <em>défaut : description SEO</em></span>
                <textarea name="ogDescription" rows="2" placeholder="Optionnel — affichée dans les partages" id="f-ogDescription"><%= d.ogDescription || '' %></textarea>
              </label>

              <label class="field">
                <span>OG Image <em>défaut : og-cover.svg du site · 1200×630 recommandé</em></span>
                <div class="image-picker">
                  <input type="text" name="image" value="<%= d.image || '' %>" placeholder="/assets/uploads/mon-image.jpg" id="f-ogImage">
                  <a href="/admin/media" target="_blank" rel="noopener" class="btn btn--ghost btn--sm">📁 Médias</a>
                </div>
              </label>
            </fieldset>

            <fieldset class="field fieldset">
              <legend>Twitter / X Card</legend>
              <label class="field">
                <span>Twitter Title <em>défaut : OG Title</em></span>
                <input type="text" name="twitterTitle" value="<%= d.twitterTitle || '' %>" placeholder="Optionnel">
              </label>
              <label class="field">
                <span>Twitter Description <em>défaut : OG Description</em></span>
                <textarea name="twitterDescription" rows="2" placeholder="Optionnel"><%= d.twitterDescription || '' %></textarea>
              </label>
              <label class="field">
                <span>Twitter Image <em>défaut : OG Image</em></span>
                <div class="image-picker">
                  <input type="text" name="twitterImage" value="<%= d.twitterImage || '' %>" placeholder="/assets/uploads/...">
                  <a href="/admin/media" target="_blank" rel="noopener" class="btn btn--ghost btn--sm">📁 Médias</a>
                </div>
              </label>
            </fieldset>

          </section>

          <% if (isCase) { %>
          <!-- ===== Metrics tab (case studies only) ===== -->
          <section class="editor-tab-pane" data-pane="metrics">
            <fieldset class="field fieldset">
              <legend>Métrique principale</legend>
              <div class="row-3">
                <label><span>Valeur</span><input type="text" name="bigMetricValue" value="<%= d.bigMetricValue || '' %>" placeholder="+247"></label>
                <label><span>Unité</span><input type="text" name="bigMetricUnit" value="<%= d.bigMetricUnit || '' %>" placeholder="%"></label>
                <label class="col-full"><span>Légende</span><input type="text" name="bigMetricLabel" value="<%= d.bigMetricLabel || '' %>" placeholder="de leads qualifiés en 90 jours"></label>
              </div>
            </fieldset>

            <fieldset class="field fieldset">
              <legend>3 sous-métriques</legend>
              <% subMetrics.forEach((m, i) => { %>
                <div class="row-3">
                  <label><span>Label <%= i+1 %></span><input type="text" name="subMetricsLabel" value="<%= m.label || '' %>" placeholder="Coût par lead"></label>
                  <label><span>Valeur</span><input type="text" name="subMetricsValue" value="<%= m.value || '' %>" placeholder="−65"></label>
                  <label><span>Unité</span><input type="text" name="subMetricsUnit" value="<%= m.unit || '' %>" placeholder="%"></label>
                </div>
              <% }) %>
            </fieldset>
          </section>
          <% } %>

        </div>

        <aside class="editor-side">
          <div class="side-panel">
            <h3>Publication</h3>
            <label class="checkbox">
              <input type="checkbox" name="published" <%= d.published !== false ? 'checked' : '' %>>
              <span>Publié (visible en ligne)</span>
            </label>
            <label class="field">
              <span>Date</span>
              <input type="date" name="date" value="<%= d.date || new Date().toISOString().slice(0,10) %>">
            </label>
            <label class="field">
              <span>Catégorie</span>
              <input type="text" name="category" value="<%= d.category || '' %>" placeholder="<%= isCase ? 'Implantologie' : 'Acquisition' %>">
            </label>
            <% if (!isCase) { %>
              <label class="field">
                <span>Temps de lecture</span>
                <input type="text" name="readTime" value="<%= d.readTime || '' %>" placeholder="8 min de lecture">
              </label>
            <% } else { %>
              <label class="field">
                <span>Lieu</span>
                <input type="text" name="location" value="<%= d.location || '' %>" placeholder="Casablanca">
              </label>
              <label class="field">
                <span>Durée</span>
                <input type="text" name="duration" value="<%= d.duration || '' %>" placeholder="6 mois">
              </label>
            <% } %>
            <label class="field">
              <span>Tag (article:tag)</span>
              <input type="text" name="tag" value="<%= d.tag || '' %>" placeholder="Meta Ads">
            </label>
          </div>

          <div class="side-panel side-actions">
            <button type="submit" class="btn btn--gold btn--lg btn--full">💾 Enregistrer &amp; publier</button>
            <a href="/admin/dashboard" class="btn btn--ghost btn--full">Annuler</a>
            <% if (!isNew) { %>
              <form method="post" action="<%= isCase ? '/admin/cases/' : '/admin/blog/' %><%= item.slug %>/delete" onsubmit="return confirm('Supprimer définitivement ?');" class="delete-form">
                <button type="submit" class="btn btn--danger btn--full">🗑 Supprimer</button>
              </form>
            <% } %>
          </div>
        </aside>
      </div>
    </form>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Tabs
      const tabs = document.querySelectorAll('.editor-tab');
      const panes = document.querySelectorAll('.editor-tab-pane');
      const activateTab = (id) => {
        tabs.forEach(t => t.classList.toggle('is-active', t.dataset.tab === id));
        panes.forEach(p => p.classList.toggle('is-active', p.dataset.pane === id));
      };
      tabs.forEach(tab => tab.addEventListener('click', () => activateTab(tab.dataset.tab)));

      // Auto-activate tab from ?tab=… query string (e.g. ?tab=seo)
      const requestedTab = new URLSearchParams(window.location.search).get('tab');
      if (requestedTab && document.querySelector(`.editor-tab[data-tab="${requestedTab}"]`)) {
        activateTab(requestedTab);
        // Scroll the tabs bar into view
        document.querySelector('.editor-tabs')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      // Markdown live preview
      const ta = document.getElementById('editor-content');
      const preview = document.getElementById('editor-preview');
      const render = () => { if (window.marked) preview.innerHTML = window.marked.parse(ta.value || ''); };
      const wait = setInterval(() => { if (window.marked) { clearInterval(wait); render(); } }, 100);
      ta.addEventListener('input', render);
      ta.addEventListener('keydown', (e) => {
        if (e.key === 'Tab') {
          e.preventDefault();
          const s = ta.selectionStart, en = ta.selectionEnd;
          ta.value = ta.value.slice(0, s) + '  ' + ta.value.slice(en);
          ta.selectionStart = ta.selectionEnd = s + 2;
          render();
        }
      });

      // Auto-slug
      const slug = document.getElementById('f-slug');
      const title = document.getElementById('f-title');
      const slugPrev = document.querySelector('[data-preview-slug]');
      const slugify = (s) => String(s).toLowerCase()
        .normalize('NFD').replace(/\p{Diacritic}/gu, '')
        .replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '').slice(0, 80);
      if (!slug.value) slug.dataset.auto = 'true';
      title.addEventListener('input', () => {
        if (slug.dataset.auto === 'true') {
          slug.value = slugify(title.value);
          if (slugPrev) slugPrev.textContent = slug.value || 'auto-genere';
          const path = document.getElementById('serp-path');
          if (path) path.textContent = path.textContent.replace(/\/[^/]+\/$/, '/' + (slug.value || 'auto-genere') + '/');
        }
        updatePreviews();
      });
      slug.addEventListener('input', () => {
        slug.dataset.auto = 'false';
        if (slugPrev) slugPrev.textContent = slug.value || 'auto-genere';
        const path = document.getElementById('serp-path');
        if (path) path.textContent = path.textContent.replace(/\/[^/]+\/$/, '/' + (slug.value || 'auto-genere') + '/');
      });

      // SERP + OG previews — live
      const fT = document.getElementById('f-title');
      const fE = document.getElementById('f-excerpt');
      const fMT = document.getElementById('f-metaTitle');
      const fSD = document.getElementById('f-seoDescription');
      const fOT = document.getElementById('f-ogTitle');
      const fOD = document.getElementById('f-ogDescription');
      const fOI = document.getElementById('f-ogImage');

      const serpT = document.getElementById('serp-title');
      const serpD = document.getElementById('serp-desc');
      const ogT = document.getElementById('og-title-prev');
      const ogD = document.getElementById('og-desc-prev');
      const ogImg = document.getElementById('og-img-prev');

      const truncate = (s, n) => s.length <= n ? s : s.slice(0, n - 1).trimEnd() + '…';

      function updatePreviews() {
        const titleText = (fMT.value || fT.value || 'Titre de la page') + (fMT.value ? '' : ' | OBM SYSTEM');
        const descText  = fSD.value || fE.value || 'Description par défaut générée à partir du résumé.';
        const ogTitle   = fOT.value || fMT.value || fT.value || 'Titre OG';
        const ogDesc    = fOD.value || fSD.value || fE.value || 'Description OG';
        const ogImage   = fOI.value || '/assets/img/og-cover.svg';

        serpT.textContent = truncate(titleText, 65);
        serpD.textContent = truncate(descText, 160);
        ogT.textContent = truncate(ogTitle, 90);
        ogD.textContent = truncate(ogDesc, 200);
        if (ogImage) ogImg.style.backgroundImage = `url("${ogImage.replace(/"/g, '%22')}")`;
      }
      [fT, fE, fMT, fSD, fOT, fOD, fOI].forEach(el => el && el.addEventListener('input', updatePreviews));
      updatePreviews();

      // Character counters
      document.querySelectorAll('[data-counter-for]').forEach(c => {
        const target = document.getElementById(c.dataset.counterFor);
        if (!target) return;
        const optimal = c.textContent.match(/\d+/)?.[0] || '60';
        const update = () => {
          c.textContent = `${target.value.length} / ${optimal} (~optimal)`;
          c.classList.toggle('over', target.value.length > parseInt(optimal));
        };
        target.addEventListener('input', update);
        update();
      });
    });
  </script>
</body>
</html>

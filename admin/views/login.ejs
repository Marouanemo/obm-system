<%
  const layoutOptions = { title: 'Connexion · OBM Admin', user: null, bodyClass: 'page-login' };
%>
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex,nofollow">
  <title>Connexion · OBM Admin</title>
  <link rel="stylesheet" href="/admin/_static/admin.css">
  <link rel="icon" type="image/svg+xml" href="/assets/img/favicon.svg">
</head>
<body class="page-login">
  <main class="login-wrap">
    <div class="login-card">
      <div class="login-card__logo">
        <span>O</span><span class="login-card__logo--silver">B</span><span>M</span>
        <span class="login-card__logo--arrow">↗</span>
      </div>
      <h1 class="login-card__title">Accès admin</h1>
      <p class="login-card__lead">OBM SYSTEM · backoffice contenu</p>

      <% if (error) { %>
        <div class="flash flash--error"><%= error %></div>
      <% } %>

      <form method="post" action="/admin/login" class="login-form">
        <input type="hidden" name="next" value="<%= next %>">
        <label>
          <span>Identifiant</span>
          <input type="text" name="username" required autocomplete="username" autofocus>
        </label>
        <label>
          <span>Mot de passe</span>
          <input type="password" name="password" required autocomplete="current-password">
        </label>
        <button type="submit" class="btn btn--gold">Se connecter</button>
      </form>

      <p class="login-card__note">Accès réservé · Toutes les tentatives sont journalisées.</p>
    </div>
  </main>
</body>
</html>

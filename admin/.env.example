# OBM SYSTEM Admin — Environment Variables

# Server
PORT=3201
NODE_ENV=production

# Auth — generate with: node -e "console.log(require('bcryptjs').hashSync('YourPassword', 12))"
# Then set the hash below (NOT the plain password)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Session secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# Paths
CONTENT_DIR=/var/www/obm-admin/content
PUBLIC_DIR=/var/www/obm-system/public
UPLOADS_DIR=/var/www/obm-system/public/assets/uploads
SITE_URL=https://obm-system.com
